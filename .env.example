# Example environment variables (copy to .env)

# Anthropic / Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-2.1

# Gmail API (OAuth2)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=state/gmail_token.json
GMAIL_USER_ID=me

# MCP Server / Email sending
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# File system watcher
WATCH_FOLDER=

# LinkedIn (optional)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Scheduling (Windows Task Scheduler / cron)
DAILY_SCHEDULE_CRON="0 9 * * *"
WEEKLY_SUMMARY_CRON="0 17 * * MON"
